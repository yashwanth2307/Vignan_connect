{
  "name": "Student Created Notification",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "student-created",
        "responseMode": "onReceived",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "vconnect-student-creation"
    },
    {
      "parameters": {
        "fromEmail": "vignanvgnt2025@gmail.com",
        "toEmail": "={{ $json.body.data.email }}",
        "subject": "Welcome to V-Connect - Account Created",
        "html": "=<h2>Welcome to V-Connect!</h2>\n<p>Hello {{ $json.body.data.name }},</p>\n<p>Your account has been successfully generated.</p>\n<ul>\n<li><b>Email:</b> {{ $json.body.data.email }}</li>\n<li><b>Password:</b> {{ $json.body.data.password }}</li>\n<li><b>Roll No:</b> {{ $json.body.data.rollNo }}</li>\n<li><b>Department:</b> {{ $json.body.data.department }}</li>\n</ul>\n<p>Please login immediately and change your password: <a href=\"http://localhost:3000\">V-Connect Portal</a></p>",
        "options": {}
      },
      "name": "Send Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [550, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Send Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {}
}
