# ============================================
# V-CONNECT 2.0 — Environment Configuration
# ============================================

# Database
DATABASE_URL="postgresql://postgres:postgrexyz@xyz:xyz/xyz_db?schema=public"

# Redis

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-prod
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

