{
  "name": "Faculty Created Notification",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "faculty-created",
        "responseMode": "onReceived",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        250,
        300
      ],
      "webhookId": "vconnect-faculty-creation"
    },
    {
      "parameters": {
        "fromEmail": "your-email@gmail.com",
        "toEmail": "={{ $json.body.data.email }}",
        "subject": "Welcome to V-Connect - Faculty Account Created",
        "html": "<h2>Welcome to V-Connect Faculty Portal!</h2>\n<p>Hello {{ $json.body.data.name }},</p>\n<p>Your faculty account has been created successfully.</p>\n<ul>\n<li><b>Email:</b> {{ $json.body.data.email }}</li>\n<li><b>Password:</b> {{ $json.body.data.password }}</li>\n<li><b>Employee ID:</b> {{ $json.body.data.empId }}</li>\n<li><b>Department:</b> {{ $json.body.data.department }}</li>\n</ul>\n<p>Login at: <a href=\"http://localhost:3000/login\">V-Connect Portal</a></p>",
        "options": {}
      },
      "name": "Send Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2,
      "position": [
        450,
        300
      ],
      "credentials": {
        "smtp": {
          "id": "",
          "name": "My SMTP Credentials"
        }
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Send Email",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {}
}
