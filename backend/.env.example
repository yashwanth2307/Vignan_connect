# Environment Variables Example for V-Connect Backend
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/vconnect_db
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REDIS_HOST=localhost
REDIS_PORT=6379
PORT=4000
QR_SESSION_DURATION_SECONDS=300
QR_TOKEN_INTERVAL_SECONDS=5
QR_TOKEN_VALIDITY_SECONDS=6
SESSION_SECRET=your-session-hmac-secret

# n8n Webhook Integration
N8N_ENABLED=false
N8N_WEBHOOK_URL=http://localhost:5678/webhook
# Set N8N_ENABLED=true after installing n8n and creating workflows

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

